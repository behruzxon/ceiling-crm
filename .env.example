# =============================================================================
# CeilingCRM SaaS — Environment Variables
# Copy to .env and fill in all values before running.
# NEVER commit .env to version control.
#
# SECURITY: Fields marked [SECRET] contain sensitive values.
# Generate strong secrets: python -c "import secrets; print(secrets.token_urlsafe(48))"
# =============================================================================

# ── Docker Compose ─────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=ceilingcrm-saas

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development                   # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-random-64-char-secret  # [SECRET] min 32 chars in production
BOT_TOKEN_ENCRYPTION_KEY=             # [SECRET] Fernet key for tenant bot tokens; generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LOG_LEVEL=DEBUG                       # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── Telegram Bot ─────────────────────────────────────────────────────────────
BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff-xxxxxxxx  # [SECRET] from @BotFather
BOT_USERNAME=yourbotusername          # without @ — used for deep links
BOT_WEBHOOK_URL=                      # empty = polling; set for production
BOT_WEBHOOK_SECRET=                   # [SECRET] random string for webhook verification
BOT_ADMIN_GROUP_ID=-1001234567890     # Telegram chat_id of the admin group
BOT_MAIN_GROUP_ID=                    # Telegram chat_id of the main customer group
BOT_ADMIN_USER_ID=                    # Telegram user_id for DM operator alerts
BOT_SUPPORT_CHAT_ID=                  # Telegram chat_id of support group
BOT_RUNTIME_MODE=single              # single = one bot; multi = tenant bots from DB

# ── Superadmin ──────────────────────────────────────────────────────────────
SUPERADMIN_TELEGRAM_ID=               # Telegram user_id; used by seed_db.py

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=25432                   # host-side port; containers use 5432
POSTGRES_USER=ceilingcrm
POSTGRES_PASSWORD=change-me-strong-password  # [SECRET]
POSTGRES_DB=ceilingcrm
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10
POSTGRES_POOL_TIMEOUT=30
# POSTGRES_ECHO=false                 # true = log all SQL (dev only)

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=26379                      # host-side port; containers use 6379
REDIS_PASSWORD=                       # [SECRET] leave empty for no auth (dev)
REDIS_DB=0                            # main application cache
REDIS_CELERY_DB=1                     # Celery broker DB
REDIS_SESSIONS_DB=2                   # FSM state storage

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_WORKERS=4
CELERY_CONCURRENCY=8
CELERY_MAX_TASKS_PER_CHILD=1000

# ── OpenAI (AI Support) ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...            # [SECRET] from platform.openai.com
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=512
OPENAI_TEMPERATURE=0.3

# ── AI Provider Override (optional — overrides OpenAI defaults) ───────────────
# AI_PROVIDER=openai                  # provider name
# AI_API_KEY=                         # [SECRET] overrides OPENAI_API_KEY if set
# AI_MODEL=gpt-4o                     # model identifier

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=                           # [SECRET] required in production
SENTRY_TRACES_SAMPLE_RATE=0.1         # 10% performance tracing in prod
SENTRY_ENVIRONMENT=development

# ── Google Sheets Export ────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=/run/secrets/google_sa.json  # [SECRET] path to SA key
GOOGLE_SHEET_ID=

# ── File Storage ────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local                 # local | s3
STORAGE_LOCAL_PATH=/app/media
AWS_ACCESS_KEY_ID=                    # [SECRET]
AWS_SECRET_ACCESS_KEY=                # [SECRET]
AWS_BUCKET_NAME=
AWS_REGION=us-east-1

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=30            # per user per window
BROADCAST_RATE_LIMIT=30               # Telegram API: max 30 msg/sec

# ── AI Rate Limiting (OpenAI cost protection) ──────────────────────────────────
AI_RATE_LIMIT_USER_WINDOW_SECONDS=60  # per-user sliding window (seconds)
AI_RATE_LIMIT_USER_MAX_REQUESTS=10    # max AI calls per user per window
AI_RATE_LIMIT_TENANT_DAILY_LIMIT=5000 # max AI calls per tenant per UTC day (0=unlimited)

# ── Business Configuration ────────────────────────────────────────────────────
CURRENCY=UZS
DEFAULT_LANGUAGE=uz
SUPPORTED_LANGUAGES=uz,ru,en
FOLLOW_UP_DAY1_HOURS=24
FOLLOW_UP_DAY3_HOURS=72
FOLLOW_UP_DAY7_HOURS=168
NEW_LEAD_ALERT_MINUTES=30             # alert if no contact within N minutes

# ── Payment Requisites (shown to clients in bot) ───────────────────────────────
PAYMENT_CARD_NUMBER=                  # bank card digits e.g. 8600123456781234
PAYMENT_CARD_HOLDER=                  # cardholder full name
PAYMENT_BANK_NAME=                    # bank name shown in requisites

# ── CTA Marketing ────────────────────────────────────────────────────────────
# CTA_ENABLED=true                    # false = suppress all CTA messages
# CTA_DISCOUNT_TEXT=...               # text for the discount CTA
# CTA_DISCOUNT_PERCENT=               # appended to button as (-N%)

# ── Click.uz Payment Gateway ──────────────────────────────────────────────────
CLICK_MERCHANT_ID=                    # Click merchant ID
CLICK_SERVICE_ID=                     # Click service ID
CLICK_SECRET_KEY=                     # [SECRET] Click secret key for signature verification
CLICK_MERCHANT_USER_ID=               # Click merchant user ID

# ── Payme.uz Payment Gateway ──────────────────────────────────────────────────
PAYME_MERCHANT_ID=                    # Payme merchant ID
PAYME_MERCHANT_KEY=                   # [SECRET] Payme merchant key for auth + signature
PAYME_TEST_MODE=true                  # true = use Payme test environment
