# =============================================================================
# CeilingCRM — Environment Variables
# Copy to .env and fill in all values before running.
# NEVER commit .env to version control.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development                   # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-random-64-char-secret
LOG_LEVEL=DEBUG                       # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── Telegram Bot ─────────────────────────────────────────────────────────────
BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff-xxxxxxxx
BOT_WEBHOOK_URL=https://your-domain.com/webhook
BOT_WEBHOOK_SECRET=change-me-random-webhook-secret
BOT_ADMIN_GROUP_ID=-1001234567890     # Telegram chat_id of the admin group (notifications)
BOT_MAIN_GROUP_ID=-1009988776655      # Telegram chat_id of the main customer group (join tracking)
BOT_SUPPORT_CHAT_ID=-1009876543210    # Telegram chat_id of support group

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ceilingcrm
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=ceilingcrm
# Assembled automatically in settings.py:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:port/db
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10
POSTGRES_POOL_TIMEOUT=30

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                       # leave empty for no auth (dev)
REDIS_DB=0                            # main application cache
REDIS_CELERY_DB=1                     # Celery broker DB
REDIS_SESSIONS_DB=2                   # FSM state storage

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_WORKERS=4
CELERY_CONCURRENCY=8
CELERY_MAX_TASKS_PER_CHILD=1000

# ── OpenAI (AI Support) ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=512
OPENAI_TEMPERATURE=0.3
AI_SYSTEM_PROMPT_FILE=shared/i18n/locales/uz/ai_system_prompt.txt

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx
SENTRY_TRACES_SAMPLE_RATE=0.1         # 10% performance tracing in prod
SENTRY_ENVIRONMENT=development

# ── Google Sheets Export ──────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=/run/secrets/google_sa.json
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# ── File Storage ──────────────────────────────────────────────────────────────
STORAGE_BACKEND=local                 # local | s3
STORAGE_LOCAL_PATH=/app/media
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=ceilingcrm-media
AWS_REGION=us-east-1

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=30            # per user per window
BROADCAST_RATE_LIMIT=30              # Telegram API: max 30 msg/sec

# ── REST API ─────────────────────────────────────────────────────────────────
API_INTERNAL_TOKEN=                   # Bearer token for /api/v1/* endpoints
                                      # Required in production. In dev, API is open if unset.

# ── Web Dashboard ───────────────────────────────────────────────────────────
WEB_DASHBOARD_USERNAME=               # HTTP Basic Auth username for web dashboard
WEB_DASHBOARD_PASSWORD=               # HTTP Basic Auth password for web dashboard
                                      # Required in production. In dev, dashboard is open if unset.
API_BASE_URL=http://api:8000          # Internal URL for web→api calls (Docker service name)
                                      # Override to http://localhost:8000 when running outside Docker.

# ── Business Configuration ────────────────────────────────────────────────────
CURRENCY=UZS
DEFAULT_LANGUAGE=uz
SUPPORTED_LANGUAGES=uz,ru,en
FOLLOW_UP_DAY1_HOURS=24
FOLLOW_UP_DAY3_HOURS=72
FOLLOW_UP_DAY7_HOURS=168
NEW_LEAD_ALERT_MINUTES=30            # alert if no contact within N minutes

# ── Agent Follow-up Engine ─────────────────────────────────────────────────
AGENT_FOLLOWUPS_ENABLED=false        # master switch for all agent follow-ups
AGENT_CATALOG_FOLLOWUP_ENABLED=false # 10-min follow-up after catalog view
AGENT_PRICE_FOLLOWUP_ENABLED=false   # 10-min follow-up after price calculation
AGENT_ORDER_FOLLOWUP_ENABLED=false   # 10-min follow-up after abandoned order form
AGENT_CATALOG_FOLLOWUP_DELAY_MINUTES=10  # delay before catalog follow-up (1 for dev testing)
AGENT_PRICE_FOLLOWUP_DELAY_MINUTES=10   # delay before price follow-up (1 for dev testing)
AGENT_ORDER_FOLLOWUP_DELAY_MINUTES=10   # delay before abandoned order follow-up (1 for dev testing)
AGENT_ADMIN_ESCALATION_ENABLED=false    # send admin alert when lead ignores follow-ups
AGENT_ADMIN_ESCALATION_AFTER_FOLLOWUPS=2  # escalate after N unanswered follow-ups
AGENT_ADMIN_ESCALATION_COOLDOWN_MINUTES=60  # min gap between escalation alerts per user
AGENT_AI_COMPOSER_ENABLED=false             # use AI to personalize follow-up messages
AGENT_AI_COMPOSER_MODEL=gpt-4o-mini         # model for composing follow-up messages
AGENT_AI_COMPOSER_TIMEOUT_SECONDS=8         # max wait for AI response
AGENT_AI_COMPOSER_MAX_TOKENS=180            # max output tokens
AGENT_DECISION_ENGINE_ENABLED=false         # enable agent decision evaluation
AGENT_DECISION_LOG_ONLY=true                # true=log decisions only, false=act on them
AGENT_DECISION_MIN_CONFIDENCE=60            # min confidence for high-impact actions (0-100)
AGENT_LEAD_SIGNAL_ENABLED=false             # extract intent/objection/urgency from free-text
AGENT_LEAD_SIGNAL_MIN_CONFIDENCE=50         # min confidence to persist signal to memory (0-100)
AGENT_LEAD_SCORING_ENABLED=false            # compute lead score from signals + events
AGENT_DYNAMIC_OFFER_ENABLED=false           # rule-based offer selection per customer
AGENT_DYNAMIC_OFFER_MIN_CONFIDENCE=60       # min confidence to persist offer to memory (0-100)
AGENT_DYNAMIC_OFFER_LOG_ONLY=true           # true=store in memory only, false=influence behavior
AGENT_CONVERSATION_POLICY_ENABLED=false     # conversation policy engine (when to reply/escalate/wait)
AGENT_CONVERSATION_POLICY_LOG_ONLY=true     # true=store in memory only, false=enforce policy
AGENT_CONVERSATION_POLICY_MIN_CONFIDENCE=60 # min confidence to persist policy to memory (0-100)
AGENT_RUNTIME_SETTINGS_ENABLED=false        # enable runtime DB settings overlay
AGENT_RUNTIME_SETTINGS_CACHE_TTL_SECONDS=30 # cache TTL for runtime settings
AGENT_RUNTIME_SETTINGS_FAIL_OPEN_TO_ENV=true # fall back to .env on DB error
AGENT_SETTINGS_MUTATION_ENABLED=false        # enable settings mutation API
AGENT_SETTINGS_REQUIRE_CONFIRMATION=true    # require confirmation token for risky changes
AGENT_SETTINGS_ALLOW_LIVE_FLAGS=false       # allow critical live flags (sender, auto execute)
AGENT_EXECUTION_API_APPROVAL_ENABLED=false   # enable approve/reject API mutations
AGENT_EXECUTION_LIVE_SENDER_ENABLED=false    # send approved executions via Telegram bot
AGENT_EXECUTION_LIVE_SENDER_BATCH_LIMIT=10  # max records processed per scheduler tick
AGENT_EXECUTION_LIVE_SENDER_REVALIDATE=true # revalidate safety before every send
AGENT_EXECUTION_LIVE_SENDER_MARK_FAILED_ON_ERROR=true # mark record failed on send error
AGENT_EXECUTION_QUEUE_ENABLED=false          # persistent DB approval queue for executions
AGENT_EXECUTION_APPROVAL_TTL_MINUTES=30     # execution proposal expires after N minutes
AGENT_EXECUTION_APPROVAL_ADMIN_NOTIFY=false # send approval request to admin group
AGENT_EXECUTION_AUTO_EXECUTE_APPROVED=false # automatically execute approved proposals
AGENT_EXECUTION_SANDBOX_ENABLED=false        # execution sandbox (validate before send)
AGENT_EXECUTION_MODE=log_only               # log_only|dry_run|canary|approval_required|live
AGENT_EXECUTION_CANARY_USER_IDS=            # comma-separated Telegram user IDs for canary
AGENT_EXECUTION_REQUIRE_APPROVAL_FOR_USER_DM=true  # require admin approval before DM
AGENT_EXECUTION_REQUIRE_APPROVAL_FOR_ADMIN_ALERT=false # admin alerts don't need approval
AGENT_EXECUTION_MAX_DAILY_ACTIONS_PER_USER=3 # max agent-initiated DMs per user per day
AGENT_EXECUTION_TRACE_ENABLED=true          # store execution trace to memory_data
AGENT_TEXT_NORMALIZATION_ENABLED=true        # Uzbek Cyrillic→Latin + typo normalization
AGENT_FUZZY_INTENT_ENABLED=true             # fuzzy keyword matching for signal extraction
AGENT_FUZZY_MAX_DISTANCE=1                  # max Levenshtein distance for fuzzy match
AGENT_RESPONSE_ORCHESTRATOR_ENABLED=false   # full agent response pipeline orchestrator
AGENT_RESPONSE_ORCHESTRATOR_LOG_ONLY=true   # true=trace only, false=can take over response
AGENT_RESPONSE_ORCHESTRATOR_MIN_CONFIDENCE=60 # min confidence for orchestrated response
AGENT_RESPONSE_ORCHESTRATOR_TRACE_ENABLED=true # store pipeline trace to memory_data
